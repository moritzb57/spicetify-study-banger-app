{
  "compilerOptions": {
    "target": "ES2017",
    "jsx": "react",
    "lib": ["ES6", "DOM", "ES2015", "ScriptHost", "ESNext"],
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}